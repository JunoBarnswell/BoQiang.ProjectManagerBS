# The browser-facing backend API. The static Nginx container does not proxy API requests.
FRONTEND_API_BASE_URL=https://api.astererp.example/api

WEB_IMAGE=boqiang.projectmanagerbs.fixed:latest
WEB_CONTAINER_NAME=boqiang.projectmanagerbs
HTTP_PORT=8080

# Domestic container image sources. Override these with an enterprise registry when needed.
NODE_IMAGE=docker.m.daocloud.io/library/node:22-bookworm-slim
DOTNET_SDK_IMAGE=docker.m.daocloud.io/mcr.microsoft.com/dotnet/sdk:10.0
DOTNET_ASPNET_IMAGE=docker.m.daocloud.io/mcr.microsoft.com/dotnet/aspnet:10.0
NGINX_IMAGE=docker.m.daocloud.io/library/nginx:1.29-alpine

# Domestic package registries used during image builds.
NPM_REGISTRY=https://registry.npmmirror.com
NUGET_SOURCE=https://repo.huaweicloud.com/repository/nuget/v3/index.json
