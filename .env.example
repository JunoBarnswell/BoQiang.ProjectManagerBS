# Public HTTP port exposed by the Nginx frontend container.
HTTP_PORT=8080

# Host directory mounted to /app/data in the backend container.
ASTERERP_DATA_DIR=./deploy-data

# This path is inside the backend container. Keep it under /app/data so it is persisted.
ASTERERP_CONNECTION_STRING=Data Source=/app/data/astererp.db

# Used for backend CORS configuration. Same-origin deployments normally keep this value.
FRONTEND_ORIGIN=http://localhost:8080
