{
  "ConnectionStrings": {
    "Default": "DataSource=./data/astererp.db"
  },
  "Database": {
    "SkipInitialize": false,
    "SkipSeed": false
  },
  "AllowedHosts": "localhost",
  "SqlSugar": {
    "LogSql": false,
    "SlowSqlThresholdMs": 800
  },
  "Scheduler": {
    "WorkerCount": 1,
    "HangfireStoragePath": "./data/astererp-hangfire.db"
  },
  "DataProtection": {
    "ApplicationName": "AsterERP.DbMigrator",
    "KeysPath": "./data/data-protection-keys"
  }
}
