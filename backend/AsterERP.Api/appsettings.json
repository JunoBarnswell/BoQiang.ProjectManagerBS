{
  "ConnectionStrings": {
    "Default": "DataSource=./data/astererp.db"
  },
  "AllowedHosts": "*",
  "Cors": {
    "FrontendOrigin": "http://localhost:5173"
  },
  "SqlSugar": {
    "LogSql": true,
    "SlowSqlThresholdMs": 800
  },
  "Scheduler": {
    "WorkerCount": 2,
    "HttpCallbackTimeoutSeconds": 10,
    "HangfireStoragePath": "./data/astererp-hangfire.db",
    "AllowedHosts": []
  },
  "ObjectStorage": {
    "Provider": "FileSystem",
    "FileSystem": {
      "BasePath": "./data/uploads",
      "AppendContainerNameToBasePath": false
    }
  },
  "DataProtection": {
    "ApplicationName": "AsterERP",
    "KeysPath": "./data/data-protection-keys"
  },
  "Messaging": {
    "Email": {
      "Enabled": false
    },
    "Sms": {
      "Enabled": false,
      "Provider": "Null"
    }
  },
  "ApplicationPublish": {
    "OutputRoot": "../../output/publish-apps",
    "RuntimeIdentifier": "win-x64",
    "SelfContained": true,
    "KeepSuccessfulCount": 5
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  }
}
