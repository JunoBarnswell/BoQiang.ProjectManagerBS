{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astererp.local/contracts/workflow-binding.latest.schema.json",
  "title": "WorkflowBindingLatestCallbackConfig",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "rules"],
  "properties": {
    "version": { "const": "latest" },
    "rules": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["ruleId", "enabled", "trigger", "assignments", "sortOrder"],
        "properties": {
          "ruleId": { "type": ["string", "null"] },
          "enabled": { "type": "boolean" },
          "trigger": { "enum": ["process-start", "node-enter", "task-complete", "task-reject", "task-return", "process-completed", "process-withdrawn", "process-terminated"] },
          "assignments": { "type": "array", "minItems": 1, "maxItems": 10 },
          "sortOrder": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
