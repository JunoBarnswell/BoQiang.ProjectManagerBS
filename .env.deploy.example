# Replace your-acr-namespace with the actual ACR namespace.
BACKEND_IMAGE=registry.cn-hangzhou.aliyuncs.com/your-acr-namespace/boqiang-projectmanagerbs-backend:latest
FRONTEND_IMAGE=registry.cn-hangzhou.aliyuncs.com/your-acr-namespace/boqiang-projectmanagerbs-frontend:latest

# Host directory mounted to /app/data in the backend container.
ASTERERP_DATA_DIR=./deploy-data
ASTERERP_CONNECTION_STRING=Data Source=/app/data/astererp.db
FRONTEND_ORIGIN=http://localhost:8080
